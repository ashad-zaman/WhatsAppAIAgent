generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Permission {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE_USERS
  MANAGE_AGENTS
  MANAGE_SETTINGS
  VIEW_ANALYTICS
  MANAGE_BILLING
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum AgentType {
  REMINDER
  CALENDAR
  DOCUMENT
  CONVERSATION
  VOICE
}

enum ReminderStatus {
  PENDING
  COMPLETED
  CANCELLED
  FAILED
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum DocumentStatus {
  PROCESSING
  INDEXED
  FAILED
}

enum Channel {
  WHATSAPP
  DASHBOARD
  VOICE
  API
}

enum MessageType {
  TEXT
  VOICE
  DOCUMENT
  IMAGE
  VIDEO
  LOCATION
  CONTACT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum CalendarProvider {
  GOOGLE
  OUTLOOK
}

enum EventStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  phone           String?          @unique
  passwordHash    String?
  fullName        String
  address         String?          @default("")
  timezone        String           @default("UTC")
  pushNotifications Boolean         @default(true)
  emailNotifications Boolean        @default(true)
  theme           String           @default("light")
  plan            SubscriptionPlan @default(FREE)
  avatarUrl       String?
  isEmailVerified Boolean          @default(false)
  isPhoneVerified Boolean          @default(false)
  twoFactorEnabled Boolean        @default(false)
  lastActiveAt    DateTime?
  encryptedData   String?          @default("") // Encrypted sensitive data (AES-256)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organizationMemberships OrganizationMember[]
  reminders                Reminder[]
  sharedReminders          SharedReminder[]        @relation("SharedWithUser")
  documents                Document[]
  calendarTokens           CalendarToken[]
  calendarEvents           CalendarEvent[]
  subscriptions            Subscription[]
  usageMetrics             UsageMetric[]
  sessions                 Session[]
  messages                 Message[]
  workflows               Workflow[]
  
  @@index([email])
  @@index([phone])
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]
  agents    Agent[]
  documents Document[]

  @@index([ownerId])
}

model OrganizationMember {
  orgId       String
  userId      String
  role        UserRole           @default(MEMBER)
  permissions Permission[]
  joinedAt    DateTime           @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@index([userId])
}

model Agent {
  id           String    @id @default(uuid())
  orgId        String
  name         String
  type         AgentType
  config       Json      @default("{}")
  systemPrompt String?
  apiKey       String?   @default("")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     Session[]
  messages     Message[]

  @@index([orgId])
  @@index([type])
}

model Reminder {
  id              String        @id @default(uuid())
  userId          String
  title           String
  description     String?
  scheduledAt     DateTime
  timezone        String        @default("UTC")
  repeatType      RepeatType    @default(NONE)
  repeatInterval  Int           @default(1)
  repeatEndDate   DateTime?
  status          ReminderStatus @default(PENDING)
  source          Channel       @default(WHATSAPP)
  metadata        Json          @default("{}")
  lastNotifiedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedWith      SharedReminder[]

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
}

model SharedReminder {
  id              String   @id @default(uuid())
  reminderId      String
  sharedWithUserId String
  permission      String   @default("view")
  createdAt       DateTime @default(now())

  reminder        Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  sharedWithUser  User     @relation("SharedWithUser", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([reminderId, sharedWithUserId])
  @@index([sharedWithUserId])
}

model Document {
  id          String         @id @default(uuid())
  userId      String
  orgId       String?
  title       String
  filePath    String
  fileType    String
  fileSize    BigInt
  version     Int            @default(1)
  metadata    Json           @default("{}")
  status      DocumentStatus @default(PROCESSING)
  chunkCount  Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  chunks      DocumentChunk[]

  @@index([userId])
  @@index([orgId])
  @@index([status])
}

model DocumentChunk {
  id          String   @id @default(uuid())
  documentId  String
  chunkIndex  Int
  chunkText   String
  tokenCount  Int
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([chunkIndex])
}

model CalendarToken {
  id           String           @id @default(uuid())
  userId       String
  provider     CalendarProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  scope        String[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model CalendarEvent {
  id          String           @id @default(uuid())
  userId      String
  provider    CalendarProvider
  externalId  String?
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  timezone    String           @default("UTC")
  location    String?
  attendees   Json             @default("[]")
  status      EventStatus      @default(SCHEDULED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([externalId])
  @@index([startTime])
}

model Subscription {
  id                    String             @id @default(uuid())
  userId                String
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  plan                  SubscriptionPlan
  status                SubscriptionStatus
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model UsageMetric {
  id          String   @id @default(uuid())
  userId      String
  metricType  String
  count       Int      @default(0)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metricType, periodStart])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  agentId      String?
  channel      Channel  @default(WHATSAPP)
  state        Json     @default("{}")
  context      Json     @default("{}")
  preferences  Json     @default("{}")
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent        Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@index([userId])
  @@index([expiresAt])
}

model Message {
  id              String           @id @default(uuid())
  sessionId       String
  userId          String
  agentId         String?
  direction       MessageDirection
  channel         Channel          @default(WHATSAPP)
  messageType     MessageType      @default(TEXT)
  content         Json
  metadata        Json             @default("{}")
  context         Json             @default("{}")
  embeddings      Json?
  createdAt       DateTime         @default(now())

  session         Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent           Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

model Workflow {
  id          String   @id @default(uuid())
  userId      String
  name        String
  type        String   @default("CUSTOM")
  schedule    String?
  trigger     String?
  steps       Json     @default("[]")
  enabled     Boolean  @default(true)
  status      String   @default("INACTIVE")
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]

  @@index([userId])
  @@index([status])
}

model WorkflowExecution {
  id          String   @id @default(uuid())
  workflowId  String
  status      String   @default("STARTED")
  result      Json?
  error       String?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
}
