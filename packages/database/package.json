{
  "name": "@whatsapp-ai/database",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "exports": {
    ".": "./src/index.ts",
    "./prisma": "./src/prisma/index.ts",
    "./mongodb": "./src/mongodb/index.ts",
    "./redis": "./src/redis/index.ts",
    "./neo4j": "./src/neo4j/index.ts",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "push": "prisma db push",
    "studio": "prisma studio",
    "db:indexes": "node scripts/create-indexes.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "mongodb": "^6.3.0",
    "neo4j-driver": "^5.17.0",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prisma": "^5.22.0",
    "typescript": "^5.4.0"
  }
}
